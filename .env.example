# ============================================================
# Root .env.example — copy to .env and fill in real values
# ============================================================

# --- MySQL ---
MYSQL_DATABASE=ecommerce_db
MYSQL_ROOT_PASSWORD=change_me
MYSQL_USER=dbuser
MYSQL_PASSWORD=change_me

# --- Backend ---
DATABASE_URL=mysql+pymysql://dbuser:change_me@db:3306/ecommerce_db
JWT_SECRET_KEY=change_me_use_long_random_string
JWT_REFRESH_SECRET_KEY=change_me_use_another_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Admin seed user ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# --- Frontend ---
VITE_API_URL=http://localhost:8000
